<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
		<Nullable>enable</Nullable>
		<UseWindowsForms>true</UseWindowsForms>
		<ImplicitUsings>enable</ImplicitUsings>
		<ApplicationIcon>Ressources\ministats_icon.ico</ApplicationIcon>

		<Version>0.0.16</Version>
		<FileVersion>0.0.16.0</FileVersion>
		<AssemblyVersion>0.0.16.0</AssemblyVersion>
		<InformationalVersion>0.0.16</InformationalVersion>

		<Company>Daniel Capilla</Company>
		<Product>MiniStats</Product>
		<AssemblyCopyright>Daniel Capilla</AssemblyCopyright>
	</PropertyGroup>

	<ItemGroup>
		
		<PackageReference Include="LibreHardwareMonitorLib" Version="0.9.4" />
	</ItemGroup>

	<ItemGroup>
		<EmbeddedResource Include="Ressources\ministats_splash.png" />
	</ItemGroup>

</Project>